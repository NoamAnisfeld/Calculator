{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "TypeScript build",
			"type": "typescript",
			"tsconfig": "tsconfig.json",
			"option": "watch",
			"problemMatcher": [
				"$tsc-watch"
			],
			"group": "build",
			"runOptions": {
				"runOn": "folderOpen"
			}
		},
		{
			"label": "SCSS build",
			"type": "shell",
			"command": "npx sass -w .:.",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"runOptions": {
				"runOn": "folderOpen"
			}
		},
		{
			"label": "Run tests",
			"type": "shell",
			"command": "npx jest --watch .\\*.test.js",
			"group": {
				"kind": "test",
				"isDefault": true
			},
			"runOptions": {
				"runOn": "folderOpen"
			}
		},
		{
			"label": "Start development server",
			"type": "shell",
			"command": "cmd \"/c py -m http.server\" | start http://localhost:8000",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"runOptions": {
				"runOn": "folderOpen"
			}
		}
	]
}